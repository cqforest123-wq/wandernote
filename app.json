{
  "expo": {
    "name": "WanderNote",
    "slug": "wandernote",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Used to calculate distance to your travel destinations"
      },
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "WanderNote需要访问您的相册来上传旅行照片",
        "NSCameraUsageDescription": "WanderNote需要访问相机来拍摄旅行照片",
        "NSPhotoLibraryAddUsageDescription": "WanderNote需要保存照片到您的相册",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.litao0729.wandernote"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0D0D"
      },
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "33b05c70-91bb-4234-872a-e8665ce39510"
      }
    },
    "owner": "litao0729"
  }
}
